rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global safety net: Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Primitives ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Hardcoded owner for bootstrapping
    function isSystemOwner() {
      return isSignedIn() && request.auth.token.email == 'taniyahpftmccormick93943@gmail.com';
    }

    // Helper to check user roles in the database
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isValidMovieStats(data) {
      return data.keys().hasAll(['viewCount']) &&
             data.keys().size() == 1 &&
             data.viewCount is int;
    }

    function isAdmin() {
      return isSignedIn() && (
        isSystemOwner() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData().role in ['Admin', 'Owner'])
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidMovie(data) {
      return data.keys().hasAll(['title', 'year', 'imageUrl']) &&
             data.title is string && data.title.size() <= 200 &&
             data.year is int && data.year > 1800 && data.year < 2100 &&
             data.imageUrl is string && data.imageUrl.size() <= 2000 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 5000)) &&
             (!('rating' in data) || (data.rating is number)) &&
             (!('genre' in data) || (data.genre is list)) &&
             (!('isBanner' in data) || (data.isBanner is bool)) &&
             (!('isPro' in data) || (data.isPro is bool)) &&
             (!('server1Url' in data) || (data.server1Url is string && data.server1Url.size() <= 2000));
    }

    function isValidReview(data) {
      return data.keys().hasAll(['movieId', 'userId', 'userName', 'rating', 'comment', 'createdAt']) &&
             data.movieId is string &&
             data.userId == request.auth.uid &&
             data.rating is int && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 1000 &&
             data.createdAt == request.time;
    }

    // --- Collection Rules ---

    // Public Collections (Movies & Series)
    match /movies/{movieId} {
      allow read: if isValidId(movieId);
      allow create, update: if isValidId(movieId) && isAdmin() && isValidMovie(incoming());
      allow delete: if isValidId(movieId) && isAdmin();

      match /stats/data {
        allow read: if true;
        allow create: if isValidMovieStats(incoming()) && incoming().viewCount == 0;
        allow update: if (isAdmin() && isValidMovieStats(incoming())) || (
          isSignedIn() && 
          isValidMovieStats(incoming()) &&
          incoming().viewCount == existing().viewCount + 1 &&
          incoming().diff(existing()).affectedKeys().hasOnly(['viewCount'])
        );
      }
    }

    match /series/{seriesId} {
      allow read: if isValidId(seriesId);
      allow create, update: if isValidId(seriesId) && isAdmin() && isValidMovie(incoming());
      allow delete: if isValidId(seriesId) && isAdmin();

      match /seasons/{seasonId} {
        allow read: if isValidId(seasonId);
        allow write: if isValidId(seasonId) && isAdmin();

        match /episodes/{episodeId} {
          allow read: if isValidId(episodeId);
          allow write: if isValidId(episodeId) && isAdmin();
        }
      }
    }

    // Global Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Data
    match /users/{userId} {
      // Users can only read their own data, Admins can read all
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      // Only Admins can modify roles and subscription info
      allow create: if isOwner(userId) && incoming().role == 'User';
      allow update: if isAdmin() || (
        isOwner(userId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])
      );

      match /profile/data {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }

      match /private/info {
        allow read, write: if isOwner(userId);
      }

      match /myList/{movieId} {
        allow read, write: if isOwner(userId);
      }

      match /history/{movieId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isVerified() && isValidReview(incoming());
      allow update, delete: if isAdmin() || (isOwner(existing().userId) && isVerified());
    }
  }
}
