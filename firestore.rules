rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Primitives ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Hardcoded owner for bootstrapping
    function isSystemOwner() {
      return isSignedIn() && request.auth.token.email == 'taniyahpftmccormick93943@gmail.com';
    }

    // Role-based access logic
    function isAdmin() {
      return isSignedIn() && (
        isSystemOwner() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Admin', 'Owner'])
      );
    }

    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Collection Rules ---

    // Public Collections (Movies & Series)
    match /movies/{movieId} {
      allow read: if true;
      allow write: if isAdmin();

      match /stats/data {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    match /series/{seriesId} {
      allow read: if true;
      allow write: if isAdmin();

      match /{allPaths=**} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // Global Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Data - Master Gate for all user content
    match /users/{userId} {
      // Allows user to read their own account info
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();

      // Deep wildcard for all subcollections (myList, watchlists, history, private, profile)
      match /{allPaths=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // Connection test document
    match /test/connection {
      allow read: if true;
    }
  }
}
