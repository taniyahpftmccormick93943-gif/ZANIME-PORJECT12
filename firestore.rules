rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Primitives ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Hardcoded owner for bootstrapping
    function isSystemOwner() {
      return isSignedIn() && request.auth.token.email == 'taniyahpftmccormick93943@gmail.com';
    }

    // Role-based access logic
    function isAdmin() {
      return isSignedIn() && (
        isSystemOwner() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Admin', 'Owner'])
      );
    }

    function isNotBanned() {
      return isSignedIn() && (
        isSystemOwner() ||
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status != 'Banned'
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['role', 'status', 'email']) &&
             data.role is string && data.role in ['User', 'Admin', 'Owner'] &&
             data.status is string && data.status in ['Active', 'Banned'] &&
             data.email is string && data.email.size() <= 256;
    }

    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Collection Rules ---

    // Public Collections (Movies & Series)
    match /movies/{movieId} {
      allow read: if true;
      allow write: if isAdmin();

      match /stats/data {
        allow read: if true;
        allow write: if isNotBanned();
      }
    }

    match /series/{seriesId} {
      allow read: if true;
      allow write: if isAdmin();

      match /stats/data {
        allow read: if true;
        allow write: if isNotBanned();
      }

      match /{allPaths=**} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // Global Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Data - Master Gate for all user content
    match /users/{userId} {
      // Allows user to read their own account info or admin to read all
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && (
        (incoming().role == 'User' && incoming().status == 'Active') ||
        isSystemOwner()
      );
      
      allow update: if (isOwner(userId) && incoming().role == existing().role && incoming().status == existing().status && isNotBanned()) || isAdmin();

      // Deep wildcard for all subcollections (myList, watchlists, history, private, profile)
      match /{allPaths=**} {
        allow read, write: if (isOwner(userId) && isNotBanned()) || isAdmin();
      }
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isNotBanned();
      allow update, delete: if isAdmin() || (isNotBanned() && resource.data.userId == request.auth.uid);
    }

    // Connection test document
    match /test/connection {
      allow read: if true;
    }
  }
}
